TELEGRAM_TOKEN=
ALLOWED_USER_IDS=123456789,987654321
VIRUSTOTAL_API_KEY=
ALLOWED_FORMATS=epub,pdf
# GITHUB_REPO=Zoeille/maman-books  # optionnel, pour désactiver les notifications de mise à jour
ANNA_ARCHIVE_URL=
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=
BOOKS_DOWNLOAD_PATH=/downloads/books
DOWNLOAD_TIMEOUT_MINUTES=15

# Local Bot API server (optional, required for files > 50 MB)
# Get API_ID and API_HASH from https://my.telegram.org
# Docker : use http://telegram-bot-api:8081 (service name)
# Local  : use http://localhost:8081
LOCAL_API_SERVER=
LOCAL_API_ID=
LOCAL_API_HASH=

# Email / Send to Kindle (optional — needs SMTP configured)
# For Gmail: use https://myaccount.google.com/apppasswords to generate App Password
# For Send to Kindle: add your sending email to "Approved Personal Document E-mail List" in Amazon
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
